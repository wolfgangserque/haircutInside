---
import { getPage } from "@lib/contentParser.astro";
import Layout from '@layouts/Layout.astro';
import Banner from "@components/Banner";

const homepage = await getPage('pages', '-index');
const { banner } = homepage?.data ?? {};

const seoTitle = "Barbershop Terbaik di Harapan Indah Bekasi | Haircut Inside Barbershop";
